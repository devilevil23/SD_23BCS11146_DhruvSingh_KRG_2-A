<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.5.2 Chrome/142.0.7444.265 Electron/39.6.1 Safari/537.36" version="29.5.2">
  <diagram name="Page-1" id="mY3FqeOSyVhbVMV0nKOM">
    <mxGraphModel dx="2716" dy="1898" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="4aXoGxgI62uzbzgTzJ1D-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Design a whatsapp systwm with proper foloowing req;&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;1. User service;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;2. Chat service;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;3 Group service;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;optimize the chat service for handling the millions of request .&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;specify the type of connection used in the diagram.&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;determine how the design will be done for LAST seen functionality.&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;implement CDC pipeline in the same architecture .&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="700" x="110" y="-180" as="geometry" />
        </mxCell>
        <mxCell id="4aXoGxgI62uzbzgTzJ1D-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Functional Requirements :&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="210" x="90" y="90" as="geometry" />
        </mxCell>
        <mxCell id="4aXoGxgI62uzbzgTzJ1D-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. User should be&amp;nbsp; able to chat one on one and in group to.&lt;div&gt;2. user should be able to share media as well like photos ,videos ,etc.&lt;/div&gt;&lt;div&gt;3.&amp;nbsp; User should be able to see if his message is read or not(read receipt).&lt;/div&gt;&lt;div&gt;4. User should be able to login and sign up.&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="400" x="90" y="110" as="geometry" />
        </mxCell>
        <mxCell id="4aXoGxgI62uzbzgTzJ1D-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Non - Functional Requirements :" vertex="1">
          <mxGeometry height="30" width="190" x="120" y="250" as="geometry" />
        </mxCell>
        <mxCell id="4aXoGxgI62uzbzgTzJ1D-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. the system should be highly relaiable.&lt;div&gt;2. high availabilty &amp;gt; consistency&lt;/div&gt;&lt;div&gt;3. There are more than 100m users and there will be approx 500m&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; messages so the app should be able to handle that .&lt;/div&gt;&lt;div&gt;4. Latency 200-300ms&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="380" x="90" y="280" as="geometry" />
        </mxCell>
